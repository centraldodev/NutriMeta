rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isNutritionistFor(patientId) {
      return signedIn()
        && exists(/databases/$(database)/documents/nutritionistLinks/$(request.auth.uid + '_' + patientId))
        && get(/databases/$(database)/documents/nutritionistLinks/$(request.auth.uid + '_' + patientId)).data.status == 'accepted';
    }

    function ownsExistingUserId() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsNewUserId() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, create, update, delete: if isSelf(userId);
    }

    match /profiles/{userId} {
      allow read, create, update, delete: if isSelf(userId) || isNutritionistFor(userId);
    }

    match /nicknames/{nickname} {
      allow read: if signedIn();
      allow create, update: if ownsNewUserId() || ownsExistingUserId();
      allow delete: if ownsExistingUserId();
    }

    match /dailyLogs/{logId} {
      allow read: if signedIn() && (
        logId.matches(request.auth.uid + '_.*') ||
        resource.data.userId == request.auth.uid ||
        isNutritionistFor(resource.data.userId)
      );
      allow create: if ownsNewUserId() || isNutritionistFor(request.resource.data.userId);
      allow update, delete: if ownsExistingUserId() || isNutritionistFor(resource.data.userId);
    }

    match /savedMeals/{mealId} {
      allow read: if ownsExistingUserId() || isNutritionistFor(resource.data.userId);
      allow create: if ownsNewUserId();
      allow update, delete: if ownsExistingUserId();
    }

    match /foodPlanMealStatuses/{statusId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        isNutritionistFor(resource.data.userId)
      );
      allow create: if ownsNewUserId();
      allow update, delete: if ownsExistingUserId();
    }

    match /foodPlans/{planId} {
      allow read: if signedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.nutritionistId == request.auth.uid ||
        isNutritionistFor(resource.data.patientId)
      );
      allow create: if signedIn() && (
        request.resource.data.patientId == request.auth.uid ||
        request.resource.data.nutritionistId == request.auth.uid ||
        isNutritionistFor(request.resource.data.patientId)
      );
      allow update, delete: if signedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.nutritionistId == request.auth.uid ||
        isNutritionistFor(resource.data.patientId)
      );
    }

    match /nutritionistLinks/{linkId} {
      allow read: if signedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.nutritionistId == request.auth.uid
      );
      allow create: if signedIn() && (
        request.resource.data.patientId == request.auth.uid ||
        request.resource.data.nutritionistId == request.auth.uid
      );
      allow update, delete: if signedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.nutritionistId == request.auth.uid
      );
    }

    match /nutritionistMessages/{messageId} {
      allow read: if signedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.nutritionistId == request.auth.uid
      );
      allow create: if signedIn() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if signedIn() && (
        resource.data.patientId == request.auth.uid ||
        resource.data.nutritionistId == request.auth.uid
      );
    }

    match /communityPosts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.authorId == request.auth.uid;
    }

    match /communityComments/{commentId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.authorId == request.auth.uid;
    }

    match /communityFollows/{followId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.followerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.followerId == request.auth.uid;
    }

    match /groups/{groupId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /groupStats/{statId} {
      allow read: if signedIn();
      allow create: if ownsNewUserId();
      allow update, delete: if ownsExistingUserId();
    }

    match /notifications/{notifId} {
      allow read, update, delete: if signedIn()
        && request.auth.uid in resource.data.targetUserIds;
      allow create: if signedIn();
    }

    match /globalFoods/{foodId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
